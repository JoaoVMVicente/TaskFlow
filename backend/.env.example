# ══════════════════════════════════════════════
# CONFIGURAÇÃO DO BANCO DE DADOS
# ══════════════════════════════════════════════

# OPÇÃO 1 — Nuvem (Supabase): use apenas a DATABASE_URL
# Pegue essa URL no painel do Supabase em: Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.xxxxx.supabase.co:5432/postgres

# OPÇÃO 2 — Local (PostgreSQL na sua máquina): comente a linha acima e use estas
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=taskflow
# DB_USER=postgres
# DB_PASSWORD=sua_senha

# ══════════════════════════════════════════════
# OUTRAS CONFIGURAÇÕES
# ══════════════════════════════════════════════

# Segredo para gerar os tokens JWT (troque por algo aleatório e longo!)
JWT_SECRET=meu_segredo_super_secreto_troque_em_producao

# URL do front-end na Vercel (para o CORS). Deixe em branco durante os testes.
FRONTEND_URL=

# Porta — o Render preenche automaticamente, não precisa mexer
PORT=3001
